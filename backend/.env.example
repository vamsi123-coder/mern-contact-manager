# Copy this file to .env and fill in your values

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/contact-manager?retryWrites=true&w=majority

# JWT secret – use a long random string in production
JWT_SECRET=replace_with_a_long_random_secret_string

# Port (Render/Railway set this automatically – leave blank or delete)
PORT=5000

# Your Vercel frontend URL (no trailing slash)
CORS_ORIGIN=https://your-app.vercel.app
