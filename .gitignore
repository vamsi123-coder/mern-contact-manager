# Root .gitignore (for MERN_website)

# Node
node_modules/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Runtime data
*.pid
*.seed
*.pid.lock

# Build output
client/dist/
client/build/
backend/dist/

# Vite / React caches
client/.vite/
client/.cache/

# Env files – ignore real secrets, allow example templates
.env
.env.local
.env.*.local
!.env.example

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS generated
Thumbs.db

# Optional: backend logs (uncomment if you create them)
# backend/*.log

